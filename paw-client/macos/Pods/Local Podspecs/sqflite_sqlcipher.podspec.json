{
  "name": "sqflite_sqlcipher",
  "version": "0.0.1",
  "summary": "SQLite plugin with SqlCipher support.",
  "description": "Access SQLite database.",
  "homepage": "https://github.com/davidmartos96/sqflite_sqlcipher",
  "license": {
    "file": "../LICENSE"
  },
  "authors": {
    "David": "davidmartos96@gmail.com"
  },
  "source": {
    "path": "."
  },
  "source_files": "Classes/**/*",
  "public_header_files": "Classes/**/*.h",
  "dependencies": {
    "FlutterMacOS": [],
    "FMDB/SQLCipher": [
      "~> 2.7.5"
    ],
    "SQLCipher": [
      "4.10.0"
    ]
  },
  "platforms": {
    "osx": "10.13"
  },
  "pod_target_xcconfig": {
    "DEFINES_MODULE": "YES",
    "HEADER_SEARCH_PATHS": "SQLCipher"
  },
  "swift_versions": "5.0",
  "resource_bundles": {
    "sqflite_sqlcipher_ios_privacy": [
      "Resources/PrivacyInfo.xcprivacy"
    ]
  },
  "swift_version": "5.0"
}

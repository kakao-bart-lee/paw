# Server
PAW_HOST=0.0.0.0
PAW_PORT=38173
PAW_WEB_DEV_PORT=4100
RUST_LOG=paw_server=debug

# Database
DATABASE_URL=postgresql://paw:paw_dev_password@localhost:35432/paw_dev

# S3/MinIO
STORAGE_BACKEND=aws
S3_ENDPOINT=http://localhost:39080
S3_BUCKET=paw-media
S3_FORCE_PATH_STYLE=true
S3_ACCESS_KEY=paw_minio
S3_SECRET_KEY=paw_minio_password
STORAGE_REGION=us-east-1

# GCP
# STORAGE_BACKEND=gcp
# GOOGLE_STORAGE_ACCESS_KEY=<gcp_access_key>
# GOOGLE_STORAGE_SECRET_KEY=<gcp_secret_key>

# Auth
JWT_SECRET=change_this_in_production_minimum_32_chars
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_DAYS=30

# OTP (Use console for dev)
OTP_PROVIDER=console
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
# Dev-only convenience: uncomment for local manual testing only.
# PAW_FIXED_OTP=137900

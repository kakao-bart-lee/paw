# Server
PAW_HOST=0.0.0.0
PAW_PORT=3000
RUST_LOG=paw_server=debug

# Database
DATABASE_URL=postgresql://paw:paw_dev_password@localhost:5432/paw_dev

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=paw-media
S3_ACCESS_KEY=paw_minio
S3_SECRET_KEY=paw_minio_password

# Auth
JWT_SECRET=change_this_in_production_minimum_32_chars
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_DAYS=30

# OTP (Use console for dev)
OTP_PROVIDER=console
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
